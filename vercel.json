{
    "version": 2,
    "builds": [
        {
            "src": "src/server/server.ts",
            "use": "@vercel/node"
        },
        {
            "src": "dist/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/src/server/server.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/dist/index.html"
        }
    ]
}
